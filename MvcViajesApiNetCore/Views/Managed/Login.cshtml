@model NugetViajesSMG.Models.LoginModel

<!-- Fondo y shapes del glassmorphism -->
<div class="glass-background">
    <div class="shape"></div>
    <div class="shape"></div>
</div>

<section class="vh-100 d-flex align-items-center justify-content-center">
    <form method="post" id="loginForm" class="glass-form">
        <h3 style="color: #92390c">Sign In</h3>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <label asp-for="Email">Correo Electrónico</label>
        <input asp-for="Email" type="text" placeholder="Email" required />
        <span asp-validation-for="Email" class="text-danger"></span>

        <label asp-for="Clave">Contraseña</label>
        <input asp-for="Clave" type="password" placeholder="Password" id="passwordField" required />
        <span asp-validation-for="Clave" class="text-danger"></span>

        <button type="submit" class="btn custom-login-btn">Log In</button>



        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">@ViewBag.Error</div>
        }

        <p style="margin-top: 20px; text-align:center;">
            ¿No tienes una cuenta?
            <a asp-controller="Managed" asp-action="Registro" style="color: #fff; text-decoration: underline;">Regístrate aquí</a>
        </p>
    </form>
</section>

<!-- Estilos Glassmorphism -->
<style>
    body {
        background-color: #080710;
    }

    .glass-background {
        position: fixed;
        width: 430px;
        height: 520px;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: 0;
    }

        .glass-background .shape {
            height: 200px;
            width: 200px;
            position: absolute;
            border-radius: 50%;
        }

            .glass-background .shape:first-child {
                background: linear-gradient(#1845ad, #23a2f6);
                left: -80px;
                top: -80px;
            }

            .glass-background .shape:last-child {
                background: linear-gradient(to right, #ff512f, #f09819);
                right: -30px;
                bottom: -80px;
            }

    .glass-form {
        position: relative;
        z-index: 1;
        width: 400px;
        background-color: rgba(255, 255, 255, 0.13);
        padding: 50px 35px;
        border-radius: 10px;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 40px rgba(8, 7, 16, 0.6);
        color: white;
    }

        .glass-form h3 {
            font-size: 32px;
            font-weight: 500;
            text-align: center;
            margin-bottom: 30px;
        }

        .glass-form label {
            display: block;
            margin-top: 20px;
            font-size: 16px;
            font-weight: 500;
        }

        .glass-form input {
            display: block;
            height: 50px;
            width: 100%;
            background-color: rgba(255, 255, 255, 0.07);
            border-radius: 3px;
            padding: 0 10px;
            margin-top: 8px;
            font-size: 14px;
            font-weight: 300;
            color: #fff;
            border: none;
        }

            .glass-form input::placeholder {
                color: #e5e5e5;
            }

        .glass-form button {
            margin-top: 40px;
            width: 100%;
            background-color: #ffffff;
            color: #080710;
            padding: 15px 0;
            font-size: 18px;
            font-weight: 600;
            border-radius: 5px;
            cursor: pointer;
            border: none;
        }

        .glass-form .social {
            margin-top: 30px;
            display: flex;
            justify-content: space-between;
        }

            .glass-form .social div {
                width: 48%;
                padding: 10px;
                border-radius: 3px;
                background-color: rgba(255, 255, 255, 0.27);
                color: #eaf0fb;
                text-align: center;
                cursor: pointer;
                transition: background 0.3s ease;
            }

                .glass-form .social div:hover {
                    background-color: rgba(255, 255, 255, 0.47);
                }

            .glass-form .social i {
                margin-right: 6px;
            }

    .text-danger {
        color: #ffbaba;
        font-size: 0.9rem;
        margin-top: 5px;
        display: block;
    }

    .alert-danger {
        background-color: rgba(255, 0, 0, 0.1);
        border: 1px solid #f00;
        color: #f00;
        text-align: center;
        padding: 10px;
        margin-top: 15px;
        border-radius: 4px;
    }
    .custom-login-btn {
    background-color: #92390c;
    color: white;
    border: none;
    transition: background 0.3s ease;
}

.custom-login-btn:hover {
    background-color: #7a2e09; /* un tono más oscuro al pasar el mouse */
}

</style>

<!-- FontAwesome (para íconos de redes sociales) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">


<script>
    function togglePassword() {
        const passwordField = document.getElementById('passwordField');
        const toggleIcon = document.getElementById('toggleIcon');

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggleIcon.classList.remove('bi-eye-slash');
            toggleIcon.classList.add('bi-eye');
        } else {
            passwordField.type = 'password';
            toggleIcon.classList.remove('bi-eye');
            toggleIcon.classList.add('bi-eye-slash');
        }
    }

    // Validación del formulario antes de enviarlo
    document.getElementById('loginForm').addEventListener('submit', function (e) {
        let isValid = true;
        const inputs = document.querySelectorAll('input[required]');

        inputs.forEach(input => {
            if (!input.value.trim()) {
                input.classList.add('is-invalid');
                isValid = false;
            } else {
                input.classList.remove('is-invalid');
            }
        });

        if (!isValid) {
            e.preventDefault();  // Evita el envío del formulario si hay campos vacíos
        }
    });
</script>
