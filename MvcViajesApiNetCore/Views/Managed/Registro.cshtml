@model NugetViajesSMG.Models.UsuarioCompletoView

<!-- Fondo glassmorphism -->
<div class="glass-background">
    <div class="shape"></div>
    <div class="shape"></div>
</div>

<section class="vh-100 d-flex align-items-center justify-content-center">
    <form method="post" class="glass-form" style="max-width: 500px; width: 100%;">
        <div class="text-center mb-4">
            @* <img src="~/images/EntdGehLogo.jpg" alt="Logo EntdGeh" style="width: 140px; height: 140px;"> *@
            <h3 style="color: #92390c" class="mt-3">Registro</h3>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <label asp-for="Nombre">Nombre</label>
        <input asp-for="Nombre" required />
        <span asp-validation-for="Nombre" class="text-danger"></span>

        <label asp-for="Email">Correo Electrónico</label>
        <input asp-for="Email" type="email" required />
        <span asp-validation-for="Email" class="text-danger"></span>

        <label asp-for="Clave">Contraseña</label>
        <input asp-for="Clave" type="password" id="claveField" required />
        <span asp-validation-for="Clave" class="text-danger"></span>

        <label asp-for="ConfirmarClave">Confirmar Contraseña</label>
        <input asp-for="ConfirmarClave" type="password" id="confirmarClaveField" required />
        <span asp-validation-for="ConfirmarClave" class="text-danger"></span>

        <label asp-for="Nacionalidad">Nacionalidad</label>
        <input asp-for="Nacionalidad" id="nacionalidad" required />
        <span asp-validation-for="Nacionalidad" class="text-danger"></span>

        <label asp-for="Edad">Edad</label>
        <input asp-for="Edad" id="edad" required />
        <span asp-validation-for="Edad" class="text-danger"></span>

        <label asp-for="PreferenciaViaje">Preferencias de Viaje</label>
        <select asp-for="PreferenciaViaje" required>
            <option value="" selected></option>
            <option value="Turístico">Turístico</option>
            <option value="Restaurante">Restaurante</option>
            <option value="Deporte">Deporte</option>
            <option value="Cultura">Cultura</option>
            <option value="Naturaleza">Naturaleza</option>
            <option value="Comercial">Comercial</option>
            <option value="Educativo">Educativo</option>
            <option value="Religioso">Religioso</option>
            <option value="Salud">Salud</option>
            <option value="Empresarial">Empresarial</option>
            <option value="Transporte">Transporte</option>
            <option value="Entretenimiento">Entretenimiento</option>
            <option value="Aventura">Aventura</option>
            <option value="Residencial">Residencial</option>
            <option value="Cívico">Cívico</option>
        </select>
        <span asp-validation-for="PreferenciaViaje" class="text-danger"></span>

        <button type="submit" class="btn custom-login-btn">Registrarse</button>

        <p style="margin-top: 20px; text-align:center;">
            ¿Ya tienes una cuenta?
            <a asp-controller="Managed" asp-action="Login" style="color: #fff; text-decoration: underline;">Inicia sesión aquí</a>
        </p>
    </form>
</section>

<h2>@ViewData["MENSAJE"]</h2>

<!-- Estilos Glassmorphism -->
<style>
    body {
        background-color: #080710;
        margin: 0;
        padding: 0;
        font-family: 'Poppins', sans-serif;
    }

    .glass-background {
        position: fixed;
        width: 430px;
        height: 520px;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: 0;
    }

        .glass-background .shape {
            height: 200px;
            width: 200px;
            position: absolute;
            border-radius: 50%;
        }

            .glass-background .shape:first-child {
                background: linear-gradient(#1845ad, #23a2f6);
                left: -80px;
                top: -80px;
            }

            .glass-background .shape:last-child {
                background: linear-gradient(to right, #ff512f, #f09819);
                right: -30px;
                bottom: -80px;
            }

    .glass-form {
        position: relative;
        z-index: 1;
        background-color: rgba(255, 255, 255, 0.13);
        padding: 40px 35px;
        border-radius: 10px;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 40px rgba(8, 7, 16, 0.6);
        color: white;
    }

        .glass-form h3 {
            font-size: 32px;
            font-weight: 500;
        }

        .glass-form label {
            display: block;
            margin-top: 20px;
            font-size: 16px;
            font-weight: 500;
        }

        .glass-form input,
        .glass-form select {
            display: block;
            height: 50px;
            width: 100%;
            background-color: rgba(255, 255, 255, 0.07);
            border-radius: 3px;
            padding: 0 10px;
            margin-top: 8px;
            font-size: 14px;
            font-weight: 300;
            color: #fff;
            border: none;
        }

            .glass-form input::placeholder {
                color: #e5e5e5;
            }

        .glass-form button {
            margin-top: 30px;
            width: 100%;
            background-color: #92390c;
            color: white;
            padding: 15px 0;
            font-size: 18px;
            font-weight: 600;
            border-radius: 5px;
            cursor: pointer;
            border: none;
            transition: background 0.3s ease;
        }

            .glass-form button:hover {
                background-color: #7a2e09;
            }

    .text-danger {
        color: #ffbaba;
        font-size: 0.9rem;
        margin-top: 5px;
        display: block;
    }

    .alert-danger {
        background-color: rgba(255, 0, 0, 0.1);
        border: 1px solid #f00;
        color: #f00;
        text-align: center;
        padding: 10px;
        margin-top: 15px;
        border-radius: 4px;
    }

    select,
    select option {
        color: black !important;
        background-color: rgba(255, 255, 255, 0.8); /* opcional: mejora contraste */
    }

</style>
